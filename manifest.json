{
  "manifest_version": 3,
  
  "name": "Traductionnello",
  "version": "1.0.0",
  "description": "Votre extension qui traduit un mot en 1 clic.",
  
  "browser_specific_settings": {
    "gecko": {
      "id": "dictionnaire-fra@example.com",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  
  "icons": {
    "128": "images/iconTraductionnello.png"
  },
  
  "action": {
    "default_popup": "popup.html",
    "default_title": "Traductionnello"
  },
  
  "permissions": [
    "storage"
  ],
  
  "host_permissions": [
    "https://api.mymemory.translated.net/*"
  ]
}